{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-iam-identity-center/refs/heads/main/json-schema/sso-admin-tag-key-list-schema.json",
  "title": "TagKeyList",
  "description": "TagKeyList schema from AWS IAM Identity Center",
  "type": "array",
  "items": {
    "type": "string",
    "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$",
    "minLength": 1,
    "maxLength": 128
  }
}